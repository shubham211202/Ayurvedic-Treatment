<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        app:title="Disease List"
        app:titleTextColor="@android:color/white" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:background="@color/colorGrayLight"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtOptional"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:text="Choose one from the following diseases"
            android:textColor="@color/colorBlack" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ITEM 1 -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/transparent_background_selector"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp">

                    <ImageView
                        android:id="@+id/img1"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/disease"
                        app:tint="@color/colorPrimary"
                        android:contentDescription="icon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/img1"
                        android:layout_marginStart="12dp"
                        android:layout_centerVertical="true"
                        android:text="Appendicitis"
                        android:textSize="18sp"
                        android:textColor="@color/colorBlack" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/colorPrimary"
                        android:contentDescription="arrow" />
                </RelativeLayout>

                <View android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorGrayLight"/>

                <!-- ITEM 2 -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/transparent_background_selector"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp">

                    <ImageView
                        android:id="@+id/img2"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/disease"
                        app:tint="@color/colorPrimary"
                        android:contentDescription="icon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/img2"
                        android:layout_marginStart="12dp"
                        android:layout_centerVertical="true"
                        android:text="Asthma"
                        android:textSize="18sp"
                        android:textColor="@color/colorBlack" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/colorPrimary"
                        android:contentDescription="arrow" />
                </RelativeLayout>

                <View android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorGrayLight"/>

                <!-- ITEM 3 -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/transparent_background_selector"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp">

                    <ImageView
                        android:id="@+id/img3"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/disease"
                        app:tint="@color/colorPrimary"
                        android:contentDescription="icon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/img3"
                        android:layout_marginStart="12dp"
                        android:layout_centerVertical="true"
                        android:text="Diabetes"
                        android:textSize="18sp"
                        android:textColor="@color/colorBlack" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/colorPrimary"
                        android:contentDescription="arrow" />
                </RelativeLayout>

                <!-- 👉 Repeat same pattern for other diseases if needed -->

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</LinearLayout>